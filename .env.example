# .env.example - Backend y Frontend Configuration

# ==========================================
# FRONTEND (Next.js) - app/layout.tsx
# ==========================================

# URL del backend para K8s/Docker/Production
# Acepta: https://api.tudominio.com, http://backend-service:80, etc.
# Si no se especifica: auto-detecta basado en hostname
# Para app.neravy.us → usa http://api.neravy.us/api (puerto 80)
NEXT_PUBLIC_BACKEND_URL=https://api.tudominio.com

# ==========================================
# BACKEND (Express) - server/index.js
# ==========================================

# Puerto donde escucha Express
# Default: 80 (para producción), 4001 (para desarrollo local)
PORT=80

# Orígenes permitidos para CORS
# Default: * (todos)
# Para production: https://frontend.tudominio.com,https://app.tudominio.com
ALLOWED_ORIGIN=*

# ==========================================
# EJEMPLOS PARA DIFERENTES AMBIENTES
# ==========================================

# LOCAL (localhost)
# NEXT_PUBLIC_BACKEND_URL=http://localhost:4001/api
# PORT=4001
# ALLOWED_ORIGIN=*

# DOCKER-COMPOSE (red interna)
# NEXT_PUBLIC_BACKEND_URL=http://backend:4001/api
# PORT=4001
# ALLOWED_ORIGIN=*

# KUBERNETES (service names)
# NEXT_PUBLIC_BACKEND_URL=http://app-backend.default.svc.cluster.local:4001/api
# PORT=4001
# ALLOWED_ORIGIN=*

# CLOUDFLARE + K8s (subdomains)
# NEXT_PUBLIC_BACKEND_URL=https://api.tudominio.com/api
# PORT=4001
# ALLOWED_ORIGIN=https://frontend.tudominio.com,https://app.tudominio.com

# AWS + Cloudfront + K8s
# NEXT_PUBLIC_BACKEND_URL=https://api-cf.tudominio.com/api
# PORT=4001
# ALLOWED_ORIGIN=https://app-cf.tudominio.com

# ==========================================
# CÓMO USARLO
# ==========================================

# 1. LOCAL:
#    $ cp .env.example .env
#    $ npm run dev

# 2. DOCKER:
#    $ docker build --build-arg NEXT_PUBLIC_BACKEND_URL=http://backend:4001/api -t app .
#    $ docker-compose up

# 3. K8s:
#    $ kubectl set env deployment/frontend NEXT_PUBLIC_BACKEND_URL=https://api.tudominio.com
#    $ kubectl rollout restart deployment/frontend

# 4. ENV FILE:
#    $ echo "NEXT_PUBLIC_BACKEND_URL=https://api.tudominio.com" > .env.local
#    $ npm run build
#    $ npm start
